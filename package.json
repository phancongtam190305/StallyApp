{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build:frontend": "vite build",
    "build:backend": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:backend": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run test:backend && npm run test:e2e"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "imapflow": "^1.3.3",
    "lucide-react": "^0.546.0",
    "mailparser": "^3.9.8",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.8",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^4.17.21",
    "@types/http-errors": "^2.0.5",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qs": "^6.15.1",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^1.2.1",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.7"
  }
}
