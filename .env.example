# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Postgres connection string.
# Prefer the Supabase pooler URL for local/dev deploys because the direct db host may require IPv6.
# Replace [YOUR-PASSWORD] with your real Supabase DB password.
# Example direct URL:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ziccfvturmgbvejguknf.supabase.co:5432/postgres"
# Example pooler URL from Supabase Dashboard -> Project Settings -> Database -> Connection pooling:
DATABASE_URL="postgresql://postgres.ziccfvturmgbvejguknf:[YOUR-PASSWORD]@YOUR-REGION.pooler.supabase.com:6543/postgres"
DATABASE_POOL_MAX=5

# Keep true for the current MVP in-memory state model.
# Set false only if every write endpoint has been migrated to targeted SQL persistence.
AUTO_PERSIST_ENABLED="true"

# Keep false on Render/Railway/local. Turn true only for serverless/debug environments
# that must reload Supabase state before every request.
RELOAD_DB_ON_EVERY_REQUEST="false"

# Keep false/missing for user testing. Set to true only when developers need mock controls.
VITE_ENABLE_DEV_TOOLS="false"

# Frontend-only deploys can call a separate backend with this URL.
# Leave empty for same-origin full-stack deploy/local monolith.
VITE_API_BASE_URL=""

# Keep false while testing locally to allow quick role switching.
# Set both to true when you want user roles resolved by email from the users table.
EMAIL_ROLE_AUTH_ENABLED="false"
VITE_EMAIL_ROLE_AUTH_ENABLED="false"

# Google OAuth login. Callback URL must be registered in Google Cloud Console:
# Local: http://localhost:3000/api/v1/auth/google/callback
# Render: https://YOUR-RENDER-SERVICE.onrender.com/api/v1/auth/google/callback
GOOGLE_OAUTH_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
FRONTEND_URL="http://localhost:3000"

# Strict mode: keep GOOGLE_OAUTH_AUTO_PROVISION=false and manually create users in Supabase.
# Open Gmail pilot mode: set true and GOOGLE_OAUTH_ALLOWED_DOMAINS="gmail.com".
# Any Google account/domain: set true and leave GOOGLE_OAUTH_ALLOWED_DOMAINS empty.
GOOGLE_OAUTH_AUTO_PROVISION="false"
GOOGLE_OAUTH_ALLOWED_DOMAINS="gmail.com"
GOOGLE_OAUTH_DEFAULT_ROLE="requester"

# ==========================================
# SMTP EMAIL CONFIGURATION (Nodemailer)
# ==========================================
# Local/dev can keep smtp. Production should use gmail_api when cloud SMTP egress times out.
EMAIL_PROVIDER="smtp"
EMAIL_ALLOW_SIMULATOR="false"

# For testing (Mailtrap):
# SMTP_HOST="sandbox.smtp.mailtrap.io"
# SMTP_PORT=587
# SMTP_USER="your_mailtrap_user"
# SMTP_PASS="your_mailtrap_password"
# SMTP_SECURE="false"

# For sending real emails (Brevo SMTP):
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT=587
# SMTP_USER="your_brevo_registered_email"
# SMTP_PASS="your_brevo_api_key_or_smtp_pass"
# SMTP_SECURE="false"

# For sending real emails (Gmail SMTP):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_USER="your_gmail@gmail.com"
# SMTP_PASS="your_gmail_app_password"
# SMTP_SECURE="true"

SMTP_FROM_NAME="Stally B2B Sourcing"
SMTP_FROM_EMAIL="no-reply@stally.com"
# Optional test safety. Leave empty to send to actual supplier emails.
EMAIL_RECIPIENT_OVERRIDE=""
SMTP_NETWORK_FAMILY=4
SMTP_DNS_TIMEOUT_MS=10000
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=15000
SMTP_SOCKET_TIMEOUT_MS=45000

# ==========================================
# GMAIL API OUTBOUND EMAIL PROVIDER
# ==========================================
# Use this in production when SMTP port 465/587 times out on cloud hosting.
# Required scope for the refresh token: https://www.googleapis.com/auth/gmail.send
GMAIL_API_CLIENT_ID=""
GMAIL_API_CLIENT_SECRET=""
GMAIL_API_REFRESH_TOKEN=""
GMAIL_API_SENDER_EMAIL="your_gmail@gmail.com"

# ==========================================
# IMAP INBOUND EMAIL POLLING
# ==========================================
# Enable this for MVP inbound supplier replies.
# For Gmail, use the same Gmail App Password as SMTP_PASS.
IMAP_POLL_ENABLED="true"
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="your_gmail@gmail.com"
IMAP_PASS="your_gmail_app_password"
IMAP_SECURE="true"
IMAP_MAILBOX="INBOX"
IMAP_POLL_INTERVAL_MS=60000

# Keep false for production/pilot so the crawler does not create fake suppliers.
SUPPLIER_DISCOVERY_ALLOW_SIMULATOR="false"
