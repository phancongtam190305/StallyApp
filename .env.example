# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ==========================================
# SMTP EMAIL CONFIGURATION (Nodemailer)
# ==========================================
# For testing (Mailtrap):
# SMTP_HOST="sandbox.smtp.mailtrap.io"
# SMTP_PORT=587
# SMTP_USER="your_mailtrap_user"
# SMTP_PASS="your_mailtrap_password"
# SMTP_SECURE="false"

# For sending real emails (Brevo SMTP):
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT=587
# SMTP_USER="your_brevo_registered_email"
# SMTP_PASS="your_brevo_api_key_or_smtp_pass"
# SMTP_SECURE="false"

# For sending real emails (Gmail SMTP):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_USER="your_gmail@gmail.com"
# SMTP_PASS="your_gmail_app_password"
# SMTP_SECURE="true"

SMTP_FROM_NAME="Stally B2B Sourcing"
SMTP_FROM_EMAIL="no-reply@stally.com"

# ==========================================
# IMAP INBOUND EMAIL POLLING
# ==========================================
# Enable this for MVP inbound supplier replies.
# For Gmail, use the same Gmail App Password as SMTP_PASS.
IMAP_POLL_ENABLED="True"
IMAP_HOST="imap.gmail.com"
IMAP_PORT=993
IMAP_USER="your_gmail@gmail.com"
IMAP_PASS="your_gmail_app_password"
IMAP_SECURE="true"
IMAP_MAILBOX="INBOX"
IMAP_POLL_INTERVAL_MS=60000
